  { name: "Calamansi", unit: "per kilo", cat: "Prutas", market: 80, grocery: 100 },
  // ISDA
  { name: "Bangus (Milkfish)", unit: "per kilo", cat: "Isda & Pagkaing-dagat", market: 160, grocery: 195 },
  { name: "Tilapia", unit: "per kilo", cat: "Isda & Pagkaing-dagat", market: 120, grocery: 150 },
  { name: "Galunggong", unit: "per kilo", cat: "Isda & Pagkaing-dagat", market: 180, grocery: 210 },
  { name: "Dilis (Dried)", unit: "per 250g", cat: "Isda & Pagkaing-dagat", market: 55, grocery: 70 },
  { name: "Pusit (Squid)", unit: "per kilo", cat: "Isda & Pagkaing-dagat", market: 220, grocery: 280 },
  { name: "Hipon (Suahe)", unit: "per kilo", cat: "Isda & Pagkaing-dagat", market: 280, grocery: 340 },
  { name: "Alimango (Mud Crab)", unit: "per kilo", cat: "Isda & Pagkaing-dagat", market: 380, grocery: 480 },
  { name: "Tulingan", unit: "per kilo", cat: "Isda & Pagkaing-dagat", market: 150, grocery: 185 },
  // KARNE
  { name: "Baboy (Liempo)", unit: "per kilo", cat: "Karne", market: 280, grocery: 310 },
  { name: "Baboy (Kasim)", unit: "per kilo", cat: "Karne", market: 250, grocery: 285 },
  { name: "Manok (Whole)", unit: "per kilo", cat: "Karne", market: 180, grocery: 210 },
  { name: "Baka (Bulalo Cut)", unit: "per kilo", cat: "Karne", market: 350, grocery: 420 },
  { name: "Baka (Giniling)", unit: "per kilo", cat: "Karne", market: 320, grocery: 380 },
  { name: "Manok Liver", unit: "per kilo", cat: "Karne", market: 120, grocery: 150 },
  // BIGAS
  { name: "Bigas (Sinandomeng)", unit: "per kilo", cat: "Bigas & Cereal", market: 48, grocery: 52 },
  { name: "Bigas (Dinurado)", unit: "per kilo", cat: "Bigas & Cereal", market: 50, grocery: 55 },
  { name: "Bigas (Milagrosa)", unit: "per kilo", cat: "Bigas & Cereal", market: 54, grocery: 58 },
  { name: "Bigas (NFA/Subsidized)", unit: "per kilo", cat: "Bigas & Cereal", market: 42, grocery: 45 },
  // ITLOG & GATAS
  { name: "Itlog (Manok)", unit: "per piece", cat: "Itlog & Gatas", market: 9, grocery: 11 },
  { name: "Itlog (Pato)", unit: "per piece", cat: "Itlog & Gatas", market: 14, grocery: 18 },
  { name: "Gatas (Powdered, 150g)", unit: "per pack", cat: "Itlog & Gatas", market: 58, grocery: 55 },
  { name: "Condensada (Carnation)", unit: "per can", cat: "Itlog & Gatas", market: 45, grocery: 43 },
  // PAMPALASA
  { name: "Asin (Salt, 500g)", unit: "per pack", cat: "Pampalasa", market: 12, grocery: 15 },
  { name: "Toyo (Soy Sauce, 1L)", unit: "per bottle", cat: "Pampalasa", market: 65, grocery: 60 },
  { name: "Patis (Fish Sauce)", unit: "per bottle", cat: "Pampalasa", market: 55, grocery: 58 },
  { name: "Bagoong Alamang", unit: "per jar (250g)", cat: "Pampalasa", market: 45, grocery: 50 },
  // LANGIS
  { name: "Mantika (Palm Oil, 1L)", unit: "per bottle", cat: "Langis & Suka", market: 82, grocery: 78 },
  { name: "Suka (Coconut, 375ml)", unit: "per bottle", cat: "Langis & Suka", market: 28, grocery: 32 },
  { name: "Bawang-sibuyas oil", unit: "per bottle 250ml", cat: "Langis & Suka", market: 45, grocery: 55 },
  // MERYENDA
  { name: "Tinapay (Tasty Bread)", unit: "per loaf", cat: "Meryenda", market: 55, grocery: 52 },
  { name: "Pancit Canton (Lucky Me)", unit: "per pack", cat: "Meryenda", market: 12, grocery: 11 },
  { name: "Skyflakes (10s)", unit: "per pack", cat: "Meryenda", market: 15, grocery: 14 },
];

let activeCategory = 'all';
let searchQuery = '';
let sortMode = 'default';

// ── RENDER ────────────────────────────────────────────────────────
function getFiltered() {
  let data = [...priceData];
  if (activeCategory !== 'all') data = data.filter(d => d.cat === activeCategory);
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    data = data.filter(d => d.name.toLowerCase().includes(q) || d.cat.toLowerCase().includes(q));
  }
  // Sort
  if (sortMode === 'savings-desc') {
    data.sort((a, b) => Math.abs(b.market - b.grocery) - Math.abs(a.market - a.grocery));
  } else if (sortMode === 'market-asc') {
    data.sort((a, b) => a.market - b.market);
  } else if (sortMode === 'grocery-asc') {
    data.sort((a, b) => a.grocery - b.grocery);
  } else if (sortMode === 'name-asc') {
    data.sort((a, b) => a.name.localeCompare(b.name));
  }
  return data;
}

function render() {
  const data = getFiltered();
  const grid = document.getElementById('itemsGrid');
  const count = document.getElementById('itemsCount');

  count.textContent = `${data.length} item${data.length !== 1 ? 's' : ''} found`;

  if (!data.length) {
    grid.innerHTML = `<div class="no-results" style="grid-column:1/-1">
      <div class="nr-icon">🔍</div>
      <p>Walang nahanap na produkto</p>
      <small>Try a different search or category</small>
    </div>`;
    return;
  }

  grid.innerHTML = data.map(item => {
    const cheaper = item.market <= item.grocery ? 'market' : 'grocery';
    const savings = Math.abs(item.market - item.grocery);
    const savingsPct = Math.round((savings / Math.max(item.market, item.grocery)) * 100);
    const winnerLabel = cheaper === 'market' ? '🛖 Palengke' : '🏪 Grocery';
    const winnerColor = cheaper === 'market' ? '#b7791f' : '#2980b9';

    return `
    <div class="item-card">
      <div class="card-top">
        <div class="card-row1">
          <div>
            <div class="item-name">${item.name}</div>
            <div class="item-unit">${item.unit}</div>
          </div>
          <div class="cat-tag">${item.cat}</div>
        </div>
        <div class="prices-compare">
          <div class="price-block market ${cheaper === 'market' ? 'cheaper-flag' : ''}">
            ${cheaper === 'market' ? '<div class="cheaper-badge">Mas Mura ✓</div>' : ''}
            <div class="pb-label market">🛖 Market</div>
            <div class="pb-price"><span class="peso">₱</span>${item.market.toLocaleString()}</div>
          </div>
          <div class="price-block grocery ${cheaper === 'grocery' ? 'cheaper-flag' : ''}">
            ${cheaper === 'grocery' ? '<div class="cheaper-badge">Mas Mura ✓</div>' : ''}
            <div class="pb-label grocery">🏪 Grocery</div>
            <div class="pb-price"><span class="peso">₱</span>${item.grocery.toLocaleString()}</div>
          </div>
        </div>
      </div>
      <div class="card-bottom">
        <div class="savings-row">
          <span class="savings-label">💰 You save</span>
          <span class="savings-amount">₱${savings} (${savingsPct}%)</span>
        </div>
        <div class="savings-bar-wrap">
          <div class="savings-bar" style="width:${Math.min(savingsPct * 2, 100)}%"></div>
        </div>
        <div class="winner-row">
          <span class="winner-icon">🏆</span>
          <span class="winner-text">Bumili sa <strong style="color:${winnerColor}">${winnerLabel}</strong> para makatipid!</span>
        </div>
      </div>
    </div>`;
  }).join('');

  updateStats();
}

function updateStats() {
  const data = getFiltered();
  let mWins = 0, gWins = 0;
  data.forEach(d => { if (d.market <= d.grocery) mWins++; else gWins++; });
  document.getElementById('statMarket').textContent = mWins;
  document.getElementById('statGrocery').textContent = gWins;
  document.getElementById('statTotal').textContent = data.length;
}

// ── FILTERS ───────────────────────────────────────────────────────
function filterCat(cat, btn) {
  activeCategory = cat;
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  render();
}

function filterItems() {
  searchQuery = document.getElementById('searchInput').value.trim();
  render();
}

function sortItems(val) {
  sortMode = val;
  render();
}

// ── MODAL ─────────────────────────────────────────────────────────
function openModal() {
  document.getElementById('modalOverlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
}

function closeModalOnBg(e) {
  if (e.target === document.getElementById('modalOverlay')) closeModal();
}

function submitReport() {
  const item = document.getElementById('repItem').value.trim();
  const loc = document.getElementById('repLocation').value;
  const price = document.getElementById('repPrice').value;
  if (!item || !loc || !price) {
    showToast('⚠️ Pakitustusan ang lahat ng fields!');
    return;
  }
  closeModal();
  document.getElementById('repItem').value = '';
  document.getElementById('repLocation').value = '';
  document.getElementById('repPrice').value = '';
  showToast('✅ Salamat! Ang iyong ulat ay natanggap na.');
}

// ── TOAST ─────────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3200);
}

// ── INIT ──────────────────────────────────────────────────────────
function init() {
  const now = new Date();
  // Set last survey date to most recent Monday
  const day = now.getDay();
  const diff = now.getDate() - day + (day === 0 ? -6 : 1);
  const lastMon = new Date(now.setDate(diff));
  const opts = { year: 'numeric', month: 'long', day: 'numeric' };
  document.getElementById('lastSurvey').textContent = lastMon.toLocaleDateString('en-PH', opts);
  render();
}

init();
</script>
