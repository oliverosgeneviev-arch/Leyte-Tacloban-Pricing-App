</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ── DATA ──────────────────────────────────────────────────────────
const priceData = [
  // GULAY
  { name: "Kamatis", unit: "per kilo", cat: "Gulay", market: 55, grocery: 75 },
